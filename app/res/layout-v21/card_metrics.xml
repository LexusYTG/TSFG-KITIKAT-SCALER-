<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:paddingTop="14.0dip"
    android:paddingBottom="14.0dip"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@id/cat_col"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="100.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8.0dip">
            <TextView
                android:textSize="9.0sp"
                android:textColor="@color/c_txt_sec"
                android:gravity="center"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="  /\\_____/\\"
                android:fontFamily="monospace" />
            <TextView
                android:textSize="11.0sp"
                android:textColor="@color/c_txt_pri"
                android:gravity="center"
                android:id="@id/tv_cat_mood"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="( ●ω● )"
                android:fontFamily="monospace" />
            <TextView
                android:textSize="9.0sp"
                android:textColor="@color/c_txt_sec"
                android:gravity="center"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="  )   (  "
                android:fontFamily="monospace" />
            <TextView
                android:textSize="9.0sp"
                android:textColor="@color/c_txt_sec"
                android:gravity="center"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text=" (_)━━(►)"
                android:fontFamily="monospace" />
        </LinearLayout>
        <View
            android:background="@color/c_border"
            android:layout_width="1.0dip"
            android:layout_height="fill_parent"
            android:layout_marginLeft="8.0dip"
            android:layout_marginRight="8.0dip" />
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginRight="12.0dip"
            android:layout_weight="1.0">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <include
                    android:id="@id/cell_fps"
                    layout="@layout/metric_cell" />
                <include
                    android:id="@id/cell_frames"
                    layout="@layout/metric_cell" />
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6.0dip">
                <include
                    android:id="@id/cell_dropped"
                    layout="@layout/metric_cell" />
                <include
                    android:id="@id/cell_efficiency"
                    layout="@layout/metric_cell" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <View
        android:background="@color/c_border"
        android:layout_width="fill_parent"
        android:layout_height="1.0dip"
        android:layout_marginTop="12.0dip"
        android:layout_marginBottom="8.0dip" />
    <LinearLayout
        android:orientation="horizontal"
        android:paddingLeft="16.0dip"
        android:paddingRight="16.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="8.5sp"
            android:textColor="@color/c_txt_muted"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:text="SESIÓN"
            android:layout_weight="1.0"
            android:fontFamily="monospace"
            android:letterSpacing="0.12" />
        <TextView
            android:textSize="11.0sp"
            android:textColor="@color/c_green"
            android:id="@id/tv_session_val"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:fontFamily="monospace" />
    </LinearLayout>
    <TextView
        android:textSize="10.0sp"
        android:textColor="@color/c_txt_muted"
        android:id="@id/tv_generation_info"
        android:paddingLeft="16.0dip"
        android:paddingRight="16.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4.0dip"
        android:fontFamily="monospace" />
</LinearLayout>