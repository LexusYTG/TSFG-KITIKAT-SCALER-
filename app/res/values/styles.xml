<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="@android:style/Theme.Holo.Light.NoActionBar">
        <item name="android:windowBackground">@color/c_bg</item>
    </style>
    <style name="SectionLabel">
        <item name="android:textSize">9.0sp</item>
        <item name="android:textColor">@color/c_txt_muted</item>
        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginLeft">2.0dip</item>
        <item name="android:layout_marginTop">22.0dip</item>
        <item name="android:layout_marginBottom">8.0dip</item>
    </style>
    <style name="ConfigTile">
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingLeft">10.0dip</item>
        <item name="android:paddingTop">10.0dip</item>
        <item name="android:paddingRight">10.0dip</item>
        <item name="android:paddingBottom">10.0dip</item>
        <item name="android:layout_height">fill_parent</item>
    </style>
    <style name="TileLabel">
        <item name="android:textSize">8.5sp</item>
        <item name="android:textColor">@color/c_txt_sec</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>
    <style name="TileValue">
        <item name="android:textSize">16.0sp</item>
        <item name="android:textColor">@color/c_txt_pri</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>
    <style name="HDivider">
        <item name="android:background">@color/c_border</item>
        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_height">1.0dip</item>
    </style>
    <style name="VDivider">
        <item name="android:background">@color/c_border</item>
        <item name="android:layout_width">1.0dip</item>
        <item name="android:layout_height">fill_parent</item>
    </style>
    <style name="ModePill">
        <item name="android:textSize">11.0sp</item>
        <item name="android:textColor">@color/c_txt_sec</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_pill_inactive</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
        <item name="android:layout_height">fill_parent</item>
        <item name="android:layout_margin">3.0dip</item>
    </style>
</resources>
